# Resibo eval — environment variables
# Copy to .env and fill in secrets. .env is gitignored.

# Weights & Biases (eval runs & metric tracking)
WANDB_PROJECT=resibo
WANDB_ENTITY=patslaurel-thinking-machines-data-science
WANDB_API_KEY=              # https://wandb.ai/authorize — keep secret

# Cloudflare R2 (pull model artifacts for eval)
R2_ENDPOINT=https://84b670d3ca847804b8fb391194a62caf.r2.cloudflarestorage.com
R2_PUBLIC=https://pub-e385d81eb05644a793783bb3e5b7447c.r2.dev
R2_BUCKET=resibo-models
R2_ACCESS_KEY_ID=           # Cloudflare → R2 → Manage API Tokens
R2_SECRET_ACCESS_KEY=       # shown once on token creation

# Hugging Face (optional — private model repo access)
HF_TOKEN=                   # https://huggingface.co/settings/tokens (read)
